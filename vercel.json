{
  "buildCommand": "NODE_OPTIONS=--max-old-space-size=4096 bun run build",
  "outputDirectory": "dist/client",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!assets/|favicon.ico|.*\\.png|.*\\.jpg|.*\\.svg|.*\\.css|.*\\.js).*)$",
      "destination": "/api/[[...all]]"
    }
  ]
}
